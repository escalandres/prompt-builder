.continue

```gitignore
# ======================================================
# Prompt Builder
# ======================================================

# ------------------------------
# Operating System
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------
# IDEs
# ------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.iml

# ------------------------------
# Logs
# ------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# Dependencies
# ------------------------------
node_modules/

# ------------------------------
# Package Managers
# ------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# ------------------------------
# Build
# ------------------------------
dist/
build/
out/
coverage/

# ------------------------------
# Cache
# ------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.tmp/
temp/

# ------------------------------
# Environment
# ------------------------------
.env
.env.*
!.env.example

# ------------------------------
# Testing
# ------------------------------
.nyc_output/
playwright-report/
test-results/

# ------------------------------
# Runtime
# ------------------------------
*.pid
*.seed
*.pid.lock

# ------------------------------
# Archives
# ------------------------------
*.zip
*.tar
*.gz
*.rar
*.7z

# ------------------------------
# Local Storage / Browser
# ------------------------------
.localstorage
.localstorage-journal

# ------------------------------
# Generated Prompt Templates
# (Only if users export them locally)
# ------------------------------
exports/
generated/
downloads/

# ------------------------------
# Temporary Files
# ------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo

# ------------------------------
# macOS
# ------------------------------
.AppleDouble
.LSOverride

# ------------------------------
# Linux
# ------------------------------
*~

# ------------------------------
# Windows
# ------------------------------
ehthumbs.db

# ------------------------------
# Optional Future Tools
# ------------------------------
.vercel/
.netlify/
.firebase/
.supabase/

# ------------------------------
# AI / LLM
# ------------------------------
.prompt-history/
.prompt-cache/
.llm-cache/
.ollama/
.lmstudio/

# ------------------------------
# Misc
# ------------------------------
*.orig
```
